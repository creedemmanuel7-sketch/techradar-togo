rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isRecruiter() {
      return isAuthenticated() && getUserRole() == 'recruiter';
    }

    // ───────────────────────────────────────────────
    // OPPORTUNITIES collection
    // ───────────────────────────────────────────────
    match /opportunities/{oppId} {
      // Anyone (including anonymous) can read opportunities
      allow read: if true;

      // Only authenticated recruiters can create opportunities
      // The publisherId in the new document must match the authenticated user
      // HACKATHON: Allow any authenticated user to do anything
      allow write: if isAuthenticated();
    }

    // ───────────────────────────────────────────────
    // USERS collection
    // ───────────────────────────────────────────────
    match /users/{userId} {
      // A user can read their own full document
      // Anyone can read limited public profile data (handled by frontend)
      allow read: if true;

      // HACKATHON: Allow any authenticated user to do anything
      allow write: if isAuthenticated();
    }
  }
}
