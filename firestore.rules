rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isRecruiter() {
      return isAuthenticated() && getUserRole() == 'recruiter';
    }

    // ───────────────────────────────────────────────
    // OPPORTUNITIES collection
    // ───────────────────────────────────────────────
    match /opportunities/{oppId} {
      // Anyone (including anonymous) can read opportunities
      allow read: if true;

      // Only authenticated recruiters can create opportunities
      // The publisherId in the new document must match the authenticated user
      allow create: if isRecruiter()
        && request.resource.data.publisherId == request.auth.uid;

      // Only the original publisher can update or delete their own opportunity
      allow update, delete: if isAuthenticated()
        && resource.data.publisherId == request.auth.uid;
    }

    // ───────────────────────────────────────────────
    // USERS collection
    // ───────────────────────────────────────────────
    match /users/{userId} {
      // A user can read their own full document
      // Anyone can read limited public profile data (handled by frontend)
      allow read: if true;

      // Only the owner can create their own user document (on registration)
      allow create: if isOwner(userId);

      // Only the owner can update their own profile
      allow update: if isOwner(userId)
        // Prevent users from changing their own role to 'recruiter' on the client
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));

      // The owner can delete their own user document (used during cascade deletion)
      allow delete: if isOwner(userId);
    }
  }
}
