rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow users to read all avatars but only upload/modify their own
    match /avatars/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
